# ============================================================================
# .gitignore — Tells Git which files to exclude from version control.
#
# WHAT THIS FILE DOES:
#   Prevents secrets (.env), compiled files (__pycache__), editor configs,
#   and build artifacts from being accidentally committed.
# ============================================================================

# Secrets — NEVER commit real API keys
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
ENV/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Database
nss_local.db

# Lock file (regenerated by uv)
uv.lock

# Agents config
.agents/
